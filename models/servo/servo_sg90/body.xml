<mujoco model="servo_body">
  <asset>
    <texture name="tex_servo" file="textures/servo_body_texture.png" type="2d"/>
    <material name="mat_servo" texture="tex_servo" specular="0.3"/>
    <mesh name="mesh_body" file="meshes/servo_body.obj" scale="1 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1" dir="0 0 -1" diffuse="1 1 1"/>

    <body name="root">
        <geom type="mesh" mesh="mesh_body" material="mat_servo"/>
        
        <site name="conn_base"              group="3" xyaxes="1 0 0  0 -1 0" type="sphere" size="0.001" rgba="1 0 0 1" pos="0 0 -.0105"/>
        <site name="conn_side_screw_left"   group="3" xyaxes="1 0 0  0 -1 0"  type="sphere" size="0.001" rgba="1 0 0 1" pos="-0.014 0 0.0075"/>
        <site name="conn_side_screw_right"  group="3" xyaxes="1 0 0  0 -1 0"  type="sphere" size="0.001" rgba="1 0 0 1" pos="0.014 0 0.0075"/>

        <body name="horn" pos="-0.005 0 0.02">
            <joint name="servo_joint" type="hinge" axis="0 0 1" range="-1.5708 1.5708" limited="true" damping="0.01"/>
            
            <geom type="box" size="0.008 0.002  0.001" pos="0 0 0" rgba="0.8 0.8 0.8 1"/>
            <site name="conn_horn"          group="3" xyaxes="1 0 0  0 -1 0" type="sphere" size="0.001" rgba="0 1 0 1" pos="0 0 0.005"/>
        </body>
    </body>
  </worldbody>

  <actuator>
      <position name="servo_actuator" joint="servo_joint" ctrlrange="-1.5708 1.5708" kp=".05"/>
  </actuator>

  <sensor>
      <jointpos name="servo_pos_sensor" joint="servo_joint"/>
  </sensor>

</mujoco>