<mujoco model="servo_demo">

  <option gravity="0 0 -9.81"/>

	<worldbody>

		<body name="wall" pos="-0.5 0 0">
			<geom type="box" size="0.05 0.2 0.2" rgba="0.8 0.6 0.4 1"/>

			<body name="servo" pos="0.1 0 0" euler="0 90 0">
				<geom type="box" size="0.05 0.09 0.075" rgba="0.2 0.8 0.2 1"/>

				<body name="servo_head" pos="0 0 0.105" >
					<geom type="box" size="0.015 0.06 0.02" rgba="0.1 0.6 0.1 1"/>
          <joint name="servo_hinge" type="hinge" axis="0 0 1" damping="0.02" frictionloss="0.005"/>

          <body name="attachmentPoint" pos="0 0 0.05">
            <geom type="box" size="0.001 0.001 0.001" rgba="0.2 0.2 0.8 1"/>
            <joint name="demo_hinge" type="hinge" axis="0 0 1" range="-7 7" damping="0.002"/>

            <body name="demo_object" pos="0 0.05 0">
              <geom type="box" size="0.02 0.05 0.02" rgba="0.2 0.2 0.8 1"/>
            </body>
          </body>
				</body>
				
			</body>

		</body>

	</worldbody>

  <actuator>
    <!-- <motor joint="servo_hinge" gear="8"/> -->
    <position joint="servo_hinge" kp="1" kv="0.05"/>
    <motor joint="demo_hinge" gear="100"/>
  </actuator>

</mujoco>