{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug RoboticsStudio",
            "type": "cppdbg",
            "request": "launch",
            // IMPORTANT: Point this to the binary you just built
            "program": "${workspaceFolder}/build/RoboticsStudio", 
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb", // Use "lldb" if on macOS
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}